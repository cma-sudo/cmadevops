---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead title={`Scan 3D / BIM · ${SITE_TITLE}`} description="Relevés LiDAR, études solaires par scan 3D, partenariat PK Architecture. Portfolio et parcours technique." />
	</head>
	<body>
		<Header />
		<main>
			<section class="intro-block">
				<h1>Scan 3D, BIM &amp; études solaires</h1>
				<p class="lede">
					Double culture <strong>scan 3D</strong> + <strong>DevOps</strong>.
					Collaboration régulière depuis 2013 avec
					<a href="https://pk-archi.com/" target="_blank" rel="noopener">PK Architecture</a>
					pour les projets de rénovation, réhabilitation et études patrimoniales en Alsace.
				</p>
			</section>

			<section class="svc-section">
				<h2>Relevés LiDAR &amp; études solaires 3D</h2>
				<p class="section-desc">Acquisition, traitement, livrables BIM — expérience et workflows éprouvés.</p>
				<p class="proof">
					<strong>Workflow ScanToBIM éprouvé avec PK Architecture depuis 2013.</strong>
					Connaissance des contraintes chantier, des PV techniques, des dossiers ERP.
				</p>

				<div class="services">
					<article class="svc">
						<h3>Relevé d'existant 3D</h3>
						<p>
							Scan 3D haute densité de bâtiments existants, intérieur et extérieur.
							Nuages de points denses pour projets de rénovation, réhabilitation, extension.
							Plusieurs dizaines de projets menés avec PK Architecture sur bâti alsacien.
						</p>
						<div class="stack">
							<span class="tag">scan-3d</span><span class="tag">point-cloud</span><span class="tag">relevé</span>
						</div>
					</article>

					<article class="svc">
						<h3>Traitement nuages de points</h3>
						<p>
							Nettoyage, segmentation, recalage, extraction d'éléments. Livrables
							CAO (DWG, IFC), plans 2D, coupes, élévations, maquettes BIM.
						</p>
						<div class="stack">
							<span class="tag">autocad</span><span class="tag">revit</span><span class="tag">cloudcompare</span>
						</div>
					</article>

					<article class="svc svc-highlight">
						<h3>Étude solaire par scan 3D</h3>
						<p>
							Avant d'investir dans du photovoltaïque : modélisation du bâti scanné
							+ simulation d'ensoleillement heure par heure, détection des ombres portées
							(cheminées, arbres, bâtiments voisins), calcul de production annuelle
							réaliste par zone de toiture. Démarche développée pour objectiver les choix
							de particuliers, architectes, copropriétés et bureaux d'études.
						</p>
						<div class="stack">
							<span class="tag">scan-3d</span><span class="tag">solaire</span><span class="tag">pvsyst</span><span class="tag">ombres-portées</span>
						</div>
					</article>

					<article class="svc">
						<h3>Partenariat PK Architecture</h3>
						<p>
							Collaboration régulière avec <a href="https://pk-archi.com/" target="_blank" rel="noopener">PK Architecture</a> depuis 2013 :
							livraison de bases CAO propres pour projets de rénovation, extensions, réhabilitations
							patrimoniales en Alsace.
						</p>
						<div class="stack">
							<span class="tag">partenariat</span><span class="tag">alsace</span><span class="tag">depuis-2013</span>
						</div>
					</article>
				</div>
			</section>

			<section class="svc-section">
				<h2>Écosystème logiciel agence</h2>
				<p class="section-desc">Audit, automatisation, veille techno et IA pour agences d'architecture.</p>

				<div class="services">
					<article class="svc">
						<h3>Cartographie parc logiciel</h3>
						<p>
							État des lieux du parc logiciel d'agence (Revit, AutoCAD, ArchiCAD, SketchUp,
							Rhino, Lumion, Twinmotion…), flux de données entre outils, points de blocage,
							licences sous-utilisées.
						</p>
						<div class="stack">
							<span class="tag">audit</span><span class="tag">revit</span><span class="tag">bim</span>
						</div>
					</article>

					<article class="svc">
						<h3>Workflows BIM / IFC</h3>
						<p>
							Standards de nommage, gabarits projet, exports IFC propres, archivage structuré.
							Documentation transmissible aux équipes.
						</p>
						<div class="stack">
							<span class="tag">bim</span><span class="tag">ifc</span><span class="tag">workflow</span>
						</div>
					</article>

					<article class="svc">
						<h3>Automatisations Dynamo / scripts métier</h3>
						<p>
							Scripts Dynamo Revit, Grasshopper Rhino, macros AutoCAD. Automatiser les tâches
							répétitives (nommage, export, contrôle qualité maquette).
						</p>
						<div class="stack">
							<span class="tag">dynamo</span><span class="tag">grasshopper</span><span class="tag">python</span>
						</div>
					</article>

					<article class="svc svc-highlight">
						<h3>Veille IA générative (architecture)</h3>
						<p>
							Veille active sur les outils IA appliqués à l'architecture :
							Midjourney, Veras, Stable Diffusion, Krea, PromeAI, plugins Revit/SketchUp,
							workflows émergents. Publié occasionnellement sur ce blog.
						</p>
						<div class="stack">
							<span class="tag">veille</span><span class="tag">ia</span><span class="tag">midjourney</span>
						</div>
					</article>
				</div>
			</section>

			<section class="refs-block">
				<h2>Références</h2>
				<p class="refs-text">
					<strong>PK Architecture</strong> (Alsace) — partenaire scan 3D / ScanToBIM depuis 2013.
					<br/><a href="https://pk-archi.com/" target="_blank" rel="noopener">pk-archi.com</a>
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.intro-block {
		padding: 2em 2em 2.5em;
		background: var(--bg-elevated);
		border: 1px solid var(--border);
		border-radius: 12px;
		margin-bottom: 3em;
	}
	h1 { margin: 0 0 0.5em; }
	.lede {
		font-size: 1.15em;
		color: var(--text);
		margin-bottom: 0;
		line-height: 1.7;
	}
	.lede strong { color: var(--accent); }
	.lede a { color: var(--accent); font-weight: 600; }
	.svc-section { margin-bottom: 3em; }
	.section-desc { color: var(--text-muted); font-style: italic; margin: -0.5em 0 1.5em; }
	.proof {
		font-size: 0.9em;
		color: var(--text-muted);
		font-style: italic;
		padding: 0.6em 1em;
		background: var(--bg-code);
		border-left: 2px solid var(--accent);
		border-radius: 4px;
		margin: 0 0 1.5em;
	}
	.proof strong { color: var(--accent); font-style: normal; }
	.services {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
		gap: 1em;
	}
	.svc {
		padding: 1.3em 1.4em;
		background: var(--bg-elevated);
		border: 1px solid var(--border);
		border-radius: 8px;
		transition: border-color 0.15s, transform 0.15s;
	}
	.svc:hover { border-color: var(--accent); transform: translateY(-2px); }
	.svc-highlight {
		border-color: var(--accent);
		background: linear-gradient(135deg, var(--bg-elevated) 0%, rgba(88, 166, 255, 0.08) 100%);
	}
	.svc h3 {
		margin: 0 0 0.5em;
		font-size: 1.05em;
		color: var(--accent);
	}
	.svc h3::before { content: ''; }
	.svc p {
		color: var(--text-muted);
		font-size: 0.95em;
		margin: 0 0 0.8em;
	}
	.stack { margin-top: 0.5em; }
	.tag {
		display: inline-block;
		font-size: 0.7em;
		font-family: 'JetBrains Mono', ui-monospace, monospace;
		padding: 2px 8px;
		background: rgba(88, 166, 255, 0.08);
		border: 1px solid rgba(88, 166, 255, 0.2);
		border-radius: 999px;
		color: var(--accent);
		margin-right: 4px;
	}
	.refs-block {
		margin-top: 2em;
		padding: 1.5em 2em;
		background: var(--bg-elevated);
		border: 1px solid var(--border);
		border-radius: 10px;
	}
	.refs-block h2 { margin-top: 0; }
	.refs-text {
		color: var(--text-muted);
		font-size: 0.95em;
		margin: 0;
		line-height: 1.8;
	}
	.refs-text strong { color: var(--text); }
</style>
