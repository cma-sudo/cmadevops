---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead title={`Architectes & bureaux d'études · ${SITE_TITLE}`} description="Relevés LiDAR, études solaires par scan 3D, audit écosystème logiciel agence d'architecture. En partenariat avec PK Architecture." />
	</head>
	<body>
		<Header />
		<main>
			<section class="intro-block">
				<h1>Pour architectes &amp; bureaux d'études</h1>
				<p class="lede">
					Double culture <strong>scan 3D</strong> + <strong>DevOps</strong> au service de vos projets et de votre agence.
					En partenariat avec <a href="https://pk-archi.com/" target="_blank" rel="noopener">PK Architecture</a>.
				</p>
			</section>

			<section class="svc-section">
				<h2>Relevés LiDAR &amp; études solaires 3D</h2>
				<p class="section-desc">Acquisition, traitement, livrables BIM — et le petit plus qui fait la différence.</p>

				<div class="services">
					<article class="svc">
						<header>
							<h3>Relevé d'existant 3D</h3>
							<span class="price">sur devis</span>
						</header>
						<p>
							Scan 3D haute densité d'un bâtiment existant, intérieur/extérieur. Nuages de points
							denses pour projets de rénovation, réhabilitation, extensions.
						</p>
						<div class="stack">
							<span class="tag">scan-3d</span><span class="tag">point-cloud</span><span class="tag">relevé</span>
						</div>
					</article>

					<article class="svc">
						<header>
							<h3>Traitement nuages de points</h3>
							<span class="price">sur devis</span>
						</header>
						<p>
							Nettoyage, segmentation, recalage, extraction d'éléments. Livrables
							CAO (DWG, IFC), plans 2D, coupes, élévations, maquettes BIM.
						</p>
						<div class="stack">
							<span class="tag">autocad</span><span class="tag">revit</span><span class="tag">cloudcompare</span>
						</div>
					</article>

					<article class="svc svc-highlight">
						<header>
							<h3>⭐ Étude solaire par scan 3D</h3>
							<span class="price">600 – 1 200 €</span>
						</header>
						<p>
							Avant d'investir <strong>10 000 à 25 000 €</strong> dans du photovoltaïque, faites modéliser
							votre toit réellement. Scan 3D précis du bâtiment + modélisation d'ensoleillement heure par heure,
							détection des ombres portées (cheminées, arbres, bâtiments voisins), calcul de production annuelle
							réaliste par zone de toiture. Livrable PDF 10-15 pages avec visuels 3D.
						</p>
						<p class="target">
							<strong>Pour qui :</strong> particuliers avant devis installateur · architectes en conception · copropriétés · bureaux d'études.
						</p>
						<div class="stack">
							<span class="tag">scan-3d</span><span class="tag">solaire</span><span class="tag">pvsyst</span><span class="tag">ombres-portées</span>
						</div>
					</article>

					<article class="svc">
						<header>
							<h3>Partenariat PK Architecture</h3>
							<span class="price">workflow établi</span>
						</header>
						<p>
							Collaboration régulière avec <a href="https://pk-archi.com/" target="_blank" rel="noopener">PK Architecture</a> :
							livraison de bases CAO propres pour projets de rénovation, extensions, réhabilitations
							patrimoniales en Alsace.
						</p>
						<div class="stack">
							<span class="tag">partenariat</span><span class="tag">alsace</span>
						</div>
					</article>
				</div>
			</section>

			<section class="svc-section">
				<h2>Écosystème logiciel agence</h2>
				<p class="section-desc">Audit, automatisation, veille techno et IA pour agences d'architecture et bureaux d'études.</p>

				<div class="services">
					<article class="svc">
						<header>
							<h3>Audit écosystème logiciel</h3>
							<span class="price">900 € (1 journée)</span>
						</header>
						<p>
							État des lieux complet : cartographie du parc logiciel (Revit, AutoCAD, ArchiCAD, SketchUp,
							Rhino, Lumion, Twinmotion…), flux de données entre outils, points de blocage, licences
							sous-utilisées. Livrable : rapport écrit avec plan d'action priorisé.
						</p>
						<div class="stack">
							<span class="tag">audit</span><span class="tag">revit</span><span class="tag">bim</span>
						</div>
					</article>

					<article class="svc">
						<header>
							<h3>Workflow BIM / IFC</h3>
							<span class="price">sur devis</span>
						</header>
						<p>
							Standards de nommage, gabarits projet, exports IFC propres, archivage structuré.
							Documentation transmissible aux équipes.
						</p>
						<div class="stack">
							<span class="tag">bim</span><span class="tag">ifc</span><span class="tag">workflow</span>
						</div>
					</article>

					<article class="svc">
						<header>
							<h3>Automatisations Dynamo / scripts métier</h3>
							<span class="price">TJM 700 €</span>
						</header>
						<p>
							Scripts Dynamo Revit, Grasshopper Rhino, macros AutoCAD. Automatiser les tâches répétitives
							(nommage, export, contrôle qualité maquette). Gain 1-3h par semaine et par collaborateur.
						</p>
						<div class="stack">
							<span class="tag">dynamo</span><span class="tag">grasshopper</span><span class="tag">python</span>
						</div>
					</article>

					<article class="svc svc-highlight">
						<header>
							<h3>⭐ Abonnement veille techno</h3>
							<span class="price">250 € / mois</span>
						</header>
						<p>
							Newsletter mensuelle ciblée architecture : nouveautés logiciels, IA générative
							(Midjourney, Veras, Stable Diffusion, Krea, PromeAI), plugins, workflows émergents.
							<strong>+ 1h de call mensuel</strong> pour répondre à vos questions concrètes.
						</p>
						<div class="stack">
							<span class="tag">veille</span><span class="tag">ia</span><span class="tag">récurrent</span>
						</div>
					</article>

					<article class="svc">
						<header>
							<h3>Formation IA générative pour archis</h3>
							<span class="price">400 € (demi-journée)</span>
						</header>
						<p>
							Prompts efficaces, outils testés et comparés (Veras, Krea, PromeAI, Midjourney),
							droits d'auteur, intégration dans un workflow Revit/SketchUp.
							Groupe de 3-6 personnes en présentiel à l'agence.
						</p>
						<div class="stack">
							<span class="tag">formation</span><span class="tag">ia-générative</span><span class="tag">midjourney</span>
						</div>
					</article>

					<article class="svc">
						<header>
							<h3>Accompagnement IA sur projet concret</h3>
							<span class="price">TJM 700 €</span>
						</header>
						<p>
							Mission ponctuelle sur un projet en cours : générer des variantes d'ambiance,
							travailler un concours, produire des visuels clients. À deux sur l'outil, vous apprenez en faisant.
						</p>
						<div class="stack">
							<span class="tag">consulting</span><span class="tag">hands-on</span>
						</div>
					</article>
				</div>
			</section>

			<section class="contact">
				<h2>Prendre contact</h2>
				<p>
					Que vous soyez architecte indépendant, agence de 3 à 30 personnes, ou bureau d'études :
					un call de 30 min pour cadrer votre besoin, puis proposition écrite.
				</p>
				<div class="cta">
					<a href="mailto:cmadevops.3n1sr@simplelogin.com?subject=Architecture" class="btn">cmadevops.3n1sr@simplelogin.com</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.intro-block {
		padding: 2em 2em 2.5em;
		background: var(--bg-elevated);
		border: 1px solid var(--border);
		border-radius: 12px;
		margin-bottom: 3em;
	}
	h1 { margin: 0 0 0.5em; }
	.lede {
		font-size: 1.15em;
		color: var(--text);
		margin-bottom: 0;
		line-height: 1.7;
	}
	.lede strong { color: var(--accent); }
	.lede a { color: var(--accent); font-weight: 600; }
	.svc-section { margin-bottom: 3em; }
	.section-desc { color: var(--text-muted); font-style: italic; margin: -0.5em 0 1.5em; }
	.services {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
		gap: 1em;
	}
	.svc {
		padding: 1.3em 1.4em;
		background: var(--bg-elevated);
		border: 1px solid var(--border);
		border-radius: 8px;
		transition: border-color 0.15s, transform 0.15s;
	}
	.svc:hover { border-color: var(--accent); transform: translateY(-2px); }
	.svc-highlight {
		border-color: var(--accent);
		background: linear-gradient(135deg, var(--bg-elevated) 0%, rgba(88, 166, 255, 0.08) 100%);
	}
	.svc header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1em;
		margin-bottom: 0.5em;
	}
	.svc h3 {
		margin: 0;
		font-size: 1.05em;
		color: var(--accent);
	}
	.svc h3::before { content: ''; }
	.price {
		font-family: 'JetBrains Mono', ui-monospace, monospace;
		font-size: 0.7em;
		color: var(--success);
		white-space: nowrap;
		background: rgba(63, 185, 80, 0.1);
		border: 1px solid rgba(63, 185, 80, 0.3);
		padding: 0.2em 0.5em;
		border-radius: 4px;
	}
	.svc p { color: var(--text-muted); font-size: 0.95em; margin: 0 0 0.8em; line-height: 1.6; }
	.svc p.target { font-size: 0.88em; color: var(--text-dim); margin-top: 0.6em; }
	.svc p.target strong { color: var(--text-muted); }
	.stack { margin-top: 0.5em; }
	.contact {
		margin-top: 3em;
		padding: 1.8em 2em;
		background: var(--bg-elevated);
		border: 1px solid var(--accent);
		border-radius: 10px;
	}
	.contact h2 { margin-top: 0; }
	.contact p { color: var(--text-muted); margin-bottom: 1em; }
	.cta { margin-top: 1em; }
	.btn {
		display: inline-block;
		padding: 0.7em 1.4em;
		border: 1px solid var(--accent);
		border-radius: 6px;
		background: var(--accent);
		color: var(--bg);
		font-family: 'JetBrains Mono', ui-monospace, monospace;
		font-size: 0.9em;
		font-weight: 600;
	}
	.btn:hover { background: var(--accent-dark); border-bottom: 1px solid var(--accent-dark); }
</style>
