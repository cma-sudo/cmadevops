---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
const base = import.meta.env.BASE_URL;

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead title={`Blog · ${SITE_TITLE}`} description="Homelab notes and DevOps rants" />
	</head>
	<body>
		<Header />
		<main>
			<h1>Blog</h1>
			<p class="lede">Notes courtes et argumentées sur ce qui casse et ce qui répare.</p>
			<ul class="posts">
				{posts.map((post) => (
					<li>
						<a href={`${base}blog/${post.id}/`}>
							<h2>{post.data.title}</h2>
							<p class="date"><FormattedDate date={post.data.pubDate} /></p>
							<p class="excerpt">{post.data.description}</p>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	.lede { font-size: 1.05em; color: var(--text-muted); margin-bottom: 2em; }
	.posts {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 1em;
	}
	.posts li a {
		display: block;
		padding: 1.3em 1.5em;
		background: var(--bg-elevated);
		border: 1px solid var(--border);
		border-radius: 8px;
		transition: border-color 0.15s, transform 0.15s;
	}
	.posts li a:hover {
		border-color: var(--accent);
		transform: translateY(-2px);
	}
	.posts h2 {
		margin: 0 0 0.2em;
		font-size: 1.3em;
		color: var(--text);
	}
	.posts h2::before { content: ''; }
	.date {
		font-family: 'JetBrains Mono', ui-monospace, monospace;
		font-size: 0.8em;
		color: var(--text-dim);
		margin: 0 0 0.5em;
	}
	.excerpt {
		color: var(--text-muted);
		font-size: 0.95em;
		margin: 0;
	}
</style>
