---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead title={`Accompagnement numérique · ${SITE_TITLE}`} description="Formation informatique seniors, support à distance, optimisation des dépenses du foyer, aide administrative en ligne. Rixheim, Mulhouse, Strasbourg, Colmar." />
	</head>
	<body>
		<Header />
		<main>
			<p class="cta-alt">
				<span>→</span> Vous êtes une PME, un indépendant tech ou vous cherchez du consulting DevOps&nbsp;?
				<a href={base + "/services-pro/"}>Voir la page Services Pro</a>
			</p>
			<section class="intro-block">
				<img src={base + "/logo-accompagnement.png"} alt="CMA Conseil Accompagnement" class="page-logo" />
				<h1>Accompagnement &amp; démarches</h1>
				<p class="lede">
					L'informatique peut être source de stress. Mon rôle : rendre les outils numériques
					<strong>simples, clairs et utiles</strong> au quotidien. À votre rythme, en français,
					<strong>sans jargon technique</strong>.
				</p>
				<div class="trust-badges">
					<span class="badge">🏡 À domicile</span>
					<span class="badge">🗣️ Patience &amp; pédagogie</span>
					<span class="badge">💳 Paiement CESU accepté</span>
					<span class="badge">✅ Crédit d'impôt 50%</span>
				</div>
			</section>

			<section class="svc-section">
				<h2>Formation & apprentissage</h2>
				<p class="section-desc">Pour apprendre à utiliser ordinateur, smartphone ou tablette, à votre rythme.</p>
				<p class="proof">
					<strong>21 000 interventions à domicile dirigées en tant qu'entrepreneur télécom.</strong>
					25 ans de management d'équipes terrain. Je sais parler simplement et prendre le temps.
				</p>

				<div class="services">
					<article class="svc">
						<header>
							<h3>Initiation ordinateur</h3>
							<span class="price">45 € / h</span>
						</header>
						<p>
							Windows, Mac, navigation internet, emails, photos, vidéos en famille.
							On part de vos besoins concrets — pas d'un manuel théorique.
						</p>
					</article>

					<article class="svc">
						<header>
							<h3>Smartphone &amp; tablette</h3>
							<span class="price">45 € / h</span>
						</header>
						<p>
							iPhone, iPad, Android. Messages, appels vidéo avec les petits-enfants,
							photos, applis essentielles (banque, SNCF, météo), sécurité et mots de passe.
						</p>
					</article>

					<article class="svc">
						<header>
							<h3>Pack découverte</h3>
							<span class="price">40 € (1 h)</span>
						</header>
						<p>
							Première séance à tarif réduit pour faire connaissance, cerner vos besoins
							et décider ensemble de la suite. Sans engagement.
						</p>
					</article>

					<article class="svc">
						<header>
							<h3>Forfait 5 heures</h3>
							<span class="price">200 € (40 €/h)</span>
						</header>
						<p>
							Cinq séances à votre domicile, étalées sur plusieurs semaines. Progression
							régulière, exercices entre les séances, support entre les cours.
						</p>
					</article>
				</div>
			</section>

			<section class="svc-section">
				<h2>Support &amp; dépannage</h2>
				<p class="section-desc">Quand quelque chose ne fonctionne plus ou semble compliqué.</p>

				<div class="services">
					<article class="svc">
						<header>
							<h3>Dépannage ponctuel</h3>
							<span class="price">50 € / intervention</span>
						</header>
						<p>
							Un souci avec votre box internet, imprimante, mail, mot de passe perdu, virus
							suspecté ? Je viens régler le problème (jusqu'à 1h à domicile).
						</p>
					</article>

					<article class="svc">
						<header>
							<h3>Support téléphonique</h3>
							<span class="price">à partir de 15 € / appel</span>
						</header>
						<p>
							Petite question, vérification, guidage pas-à-pas par téléphone. Pour les
							situations qui ne nécessitent pas un déplacement.
						</p>
					</article>

					<article class="svc svc-highlight">
						<header>
							<h3>🎧 Abonnement tranquillité</h3>
							<span class="price">29 € / mois</span>
						</header>
						<p>
							Support illimité par téléphone + 1 intervention à domicile par trimestre.
							Idéal pour être rassuré au quotidien. Une ligne dédiée vous est attribuée
							à la souscription.
						</p>
					</article>
				</div>
			</section>

			<section class="svc-section">
				<h2>Administratif en ligne</h2>
				<p class="section-desc">Les démarches numériques sont devenues incontournables. Je vous accompagne.</p>

				<div class="services">
					<article class="svc">
						<header>
							<h3>France Connect &amp; comptes officiels</h3>
							<span class="price">50 € (1h)</span>
						</header>
						<p>
							Création, sécurisation et récupération de vos comptes : Impôts, Ameli,
							CAF, carte grise, retraites. Je mets tout en place et je vous explique.
						</p>
					</article>

					<article class="svc">
						<header>
							<h3>Assistance démarches</h3>
							<span class="price">45 € / h</span>
						</header>
						<p>
							Déclaration d'impôts en ligne, prise de rendez-vous médical, relevé de
							points, espace client opérateur. Je vous accompagne, vous restez aux commandes.
						</p>
					</article>
				</div>
			</section>

			<section class="svc-section">
				<h2>Démarches administratives &amp; vie courante</h2>
				<p class="section-desc">Retraite, impôts, frontalier France-Suisse. Je monte les dossiers avec vous.</p>
				<p class="proof">
					🇨🇭 <strong>Je suis suisse. 12 ans salarié Swisscom à Delémont.</strong>
					Je connais LAMal, LPP, impôt à la source et AVS <em>de l'intérieur</em>. Allemand professionnel.
				</p>

				<div class="services">
					<article class="svc">
						<header>
							<h3>Constitution dossier retraite</h3>
							<span class="price">120 € (forfait)</span>
						</header>
						<p>
							Relevé de carrière, vérification des trimestres, simulation, rachats éventuels,
							dépôt du dossier auprès des caisses (CNAV, Agirc-Arrco, RSI). Vous récupérez
							un dossier complet, prêt à envoyer.
						</p>
					</article>

					<article class="svc">
						<header>
							<h3>Pension de réversion</h3>
							<span class="price">90 € (forfait)</span>
						</header>
						<p>
							Montage du dossier de réversion après décès du conjoint, calcul des droits,
							pièces justificatives, suivi auprès des caisses de retraite concernées.
						</p>
					</article>

					<article class="svc svc-highlight">
						<header>
							<h3>🇨🇭 Accompagnement frontalier France-Suisse</h3>
							<span class="price">80 € / h</span>
						</header>
						<p>
							LAMal vs CMU, 2ᵉ pilier, statut quasi-résident, déclaration des revenus
							suisses (formulaires 2047 et 3916). <strong>Je suis suisse, j'ai travaillé 12 ans à Delémont —
							je connais le système de l'intérieur.</strong>
						</p>
					</article>

					<article class="svc">
						<header>
							<h3>Assistance déclaration d'impôts</h3>
							<span class="price">à partir de 70 €</span>
						</header>
						<p>
							Remplissage des déclarations 2042 / 2047, cases souvent oubliées,
							crédits d'impôt, mise à jour des comptes bancaires. Je prépare, vous validez.
						</p>
					</article>
				</div>

				<p class="disclaimer">
					<strong>Mention légale :</strong> Assistance administrative et aide à la constitution
					de dossiers. Je ne me substitue pas à un expert-comptable, un avocat fiscaliste
					ou un conseiller en investissement financier (professions réglementées).
				</p>
			</section>

			<section class="svc-section">
				<h2>Optimisation des dépenses du foyer</h2>
				<p class="section-desc">Un regard neuf sur vos factures et abonnements peut faire économiser plusieurs centaines d'euros par an.</p>
				<p class="proof">
					<strong>15 ans de pilotage de P&amp;L et de budgets opérationnels.</strong>
					Je sais lire une facture et traquer les fuites. CAPEX / OPEX, c'est mon quotidien.
				</p>

				<div class="services">
					<article class="svc">
						<header>
							<h3>Audit énergie &amp; télécoms</h3>
							<span class="price">90 € (forfait)</span>
						</header>
						<p>
							Analyse de vos factures électricité, gaz, internet, mobile. Identification
							des économies possibles (changement d'offre, résiliation d'options inutiles).
							Rapport écrit avec recommandations.
						</p>
					</article>

					<article class="svc">
						<header>
							<h3>Revue des abonnements</h3>
							<span class="price">60 € (forfait)</span>
						</header>
						<p>
							Netflix, Canal+, Amazon, Spotify, salles de sport, assurances multiples…
							On fait le tri ensemble. Souvent 15 à 40 €/mois économisés.
						</p>
					</article>

					<article class="svc">
						<header>
							<h3>Accompagnement changement de fournisseur</h3>
							<span class="price">inclus dans l'audit</span>
						</header>
						<p>
							Après l'audit, je vous accompagne pour faire les démarches de
							changement — résiliations, souscriptions, suivi. Zéro stress.
						</p>
					</article>
				</div>
			</section>

			<section class="contact">
				<h2>Pourquoi faire appel à moi</h2>
				<ul class="why">
					<li><strong>Je parle français clair</strong> — aucun jargon, j'explique comme à un ami</li>
					<li><strong>Je prends le temps</strong> — jamais pressé, jamais condescendant</li>
					<li><strong>Je me déplace à votre domicile</strong> — Rixheim, Mulhouse, Illzach, Brunstatt, Riedisheim</li>
					<li><strong>Paiement CESU</strong> — crédit d'impôt de 50% sur les heures de formation et d'assistance</li>
					<li><strong>Première séance à tarif réduit</strong> — on fait connaissance sans engagement</li>
				</ul>

				<div class="cta-block">
					<h3>Prendre contact</h3>
					<p>Le plus simple : appelez ou envoyez un SMS. On discute de votre besoin, et on cale un rendez-vous.</p>
					<div class="cta">
						<a href="mailto:cmadevops.3n1sr@simplelogin.com" class="btn">cmadevops.3n1sr@simplelogin.com</a>
					</div>
					<p class="zone-note">
						<strong>Zone d'intervention :</strong> Rixheim, Mulhouse, Illzach, Brunstatt, Riedisheim, Habsheim, Sausheim et environs. <strong>Déplacement inclus</strong> dans un rayon de 15 km — pas de frais cachés.
					</p>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.intro-block {
		padding: 2em 2em 2.5em;
		background: var(--bg-elevated);
		border: 1px solid var(--border);
		border-radius: 12px;
		margin-bottom: 3em;
		text-align: center;
	}
	.page-logo {
		display: block;
		width: 140px;
		height: auto;
		margin: 0 auto 1em;
		background: #fff;
		border-radius: 12px;
		padding: 0.5em;
	}
	.intro-block h1 { text-align: left; }
	.intro-block .lede { text-align: left; }
	.trust-badges { justify-content: flex-start; }
	h1 { margin: 0 0 0.5em; }
	.lede {
		font-size: 1.15em;
		color: var(--text);
		margin-bottom: 1.5em;
		line-height: 1.7;
	}
	.lede strong { color: var(--accent); }
	.trust-badges {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6em;
	}
	.badge {
		font-size: 0.88em;
		padding: 0.5em 0.9em;
		background: var(--bg);
		border: 1px solid var(--border);
		border-radius: 20px;
		color: var(--text-muted);
	}
	.svc-section { margin-bottom: 3em; }
	.section-desc { color: var(--text-muted); font-style: italic; margin: -0.5em 0 1.5em; }
	.services {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 1em;
	}
	.svc {
		padding: 1.3em 1.4em;
		background: var(--bg-elevated);
		border: 1px solid var(--border);
		border-radius: 8px;
		transition: border-color 0.15s, transform 0.15s;
	}
	.svc:hover { border-color: var(--accent); transform: translateY(-2px); }
	.svc-highlight {
		border-color: var(--accent);
		background: linear-gradient(135deg, var(--bg-elevated) 0%, rgba(88, 166, 255, 0.08) 100%);
	}
	.cta-alt {
		font-size: 0.9em;
		padding: 0.8em 1em;
		background: var(--bg-elevated);
		border: 1px solid var(--border);
		border-radius: 6px;
		margin: 0 0 1.5em;
		color: var(--text-muted);
	}
	.cta-alt a { font-weight: 600; }
	.cta-alt span { color: var(--accent); margin-right: 0.4em; }
	.disclaimer {
		font-size: 0.82em;
		color: var(--text-dim);
		font-style: italic;
		margin: 1.5em 0 0;
		padding: 0.9em 1.1em;
		background: var(--bg);
		border-left: 3px solid var(--warning);
		border-radius: 4px;
		line-height: 1.6;
	}
	.disclaimer strong { color: var(--warning); font-style: normal; }
	.proof {
		font-size: 0.9em;
		color: var(--text-muted);
		font-style: italic;
		padding: 0.6em 1em;
		background: var(--bg-code);
		border-left: 2px solid var(--accent);
		border-radius: 4px;
		margin: -0.3em 0 1.5em;
	}
	.proof strong { color: var(--accent); font-style: normal; }
	.proof em { font-style: italic; color: var(--text); }
	.svc header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1em;
		margin-bottom: 0.5em;
	}
	.svc h3 {
		margin: 0;
		font-size: 1.1em;
		color: var(--text);
	}
	.svc h3::before { content: ''; }
	.price {
		font-size: 0.85em;
		color: var(--success);
		white-space: nowrap;
		background: rgba(63, 185, 80, 0.1);
		border: 1px solid rgba(63, 185, 80, 0.3);
		padding: 0.3em 0.7em;
		border-radius: 4px;
		font-weight: 600;
	}
	.svc p {
		color: var(--text-muted);
		font-size: 0.95em;
		margin: 0;
		line-height: 1.6;
	}
	.contact {
		margin-top: 3em;
		padding: 2em;
		background: var(--bg-elevated);
		border: 1px solid var(--accent);
		border-radius: 10px;
	}
	.contact h2 { margin-top: 0; }
	.why { list-style: none; padding: 0; margin: 0 0 2em; }
	.why li {
		padding: 0.6em 0 0.6em 1.8em;
		position: relative;
		color: var(--text-muted);
		line-height: 1.6;
	}
	.why li::before {
		content: '✓';
		position: absolute;
		left: 0;
		color: var(--success);
		font-weight: 700;
	}
	.why strong { color: var(--text); }
	.cta-block {
		padding-top: 1em;
		border-top: 1px solid var(--border);
	}
	.cta-block h3 { margin: 0.5em 0; font-size: 1.2em; }
	.cta-block h3::before { content: ''; }
	.cta-block p { color: var(--text-muted); margin-bottom: 1em; }
	.cta { margin: 1em 0; }
	.btn {
		display: inline-block;
		padding: 0.8em 1.6em;
		border: 1px solid var(--accent);
		border-radius: 6px;
		background: var(--accent);
		color: var(--bg);
		font-size: 1em;
		font-weight: 600;
	}
	.btn:hover { background: var(--accent-dark); border-bottom: 1px solid var(--accent-dark); }
	.zone-note {
		font-size: 0.85em !important;
		color: var(--text-dim) !important;
		margin-top: 1em !important;
	}
</style>
