---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="fr">
	<head>
		<BaseHead title={`Conformité & ouverture ERP · ${SITE_TITLE}`} description="Coordination ERP, constitution de dossiers commission de sécurité, accompagnement ouverture d'établissement. Missions menées en Alsace." />
	</head>
	<body>
		<Header />
		<main>
			<section class="intro-block">
				<h1>Conformité &amp; ouverture d'établissements</h1>
				<p class="lede">
					<strong>Coordination ERP</strong>, constitution de dossiers commission de sécurité,
					accompagnement d'ouverture d'établissement HCR. Missions menées en Alsace en parallèle
					des activités d'infrastructure télécom et scan 3D.
				</p>
				<div class="refs">
					<span class="ref-label">Références :</span>
					<strong>AG Bar (Altkirch)</strong> · <strong>Le Track (Blotzheim)</strong>
				</div>
			</section>

			<section class="svc-section">
				<h2>Domaines d'intervention</h2>
				<p class="section-desc">Ce que j'ai mené comme missions ERP / HCR depuis 2018.</p>
				<p class="proof">
					<strong>15 ans de gestion QSE et sécurité chantier chez Swisscom</strong> (Cablex Delémont)
					+ coordination dossiers ERP avec PK Architecture depuis 2013. Habitude des PV,
					certificats, bureaux de contrôle.
				</p>

				<div class="services">
					<article class="svc">
						<h3>Rédaction DUER</h3>
						<p>
							Document Unique d'Évaluation des Risques pour établissements HCR :
							visite terrain, identification des unités de travail, évaluation des risques,
							plan d'action priorisé. Affichage obligatoire et registre numérique livrés.
						</p>
					</article>

					<article class="svc">
						<h3>Audit conformité HCR</h3>
						<p>
							Checklist complète : sécurité incendie (extincteurs, BAES), affichages obligatoires,
							HACCP cuisine, registre unique du personnel, conventions collectives, RGPD basique.
							Rapport écrit avec priorités.
						</p>
					</article>

					<article class="svc svc-highlight">
						<h3>Constitution dossier commission de sécurité</h3>
						<p>
							Analyse PV coupe-feu, certificats, FDS produits, documents fournisseurs,
							attestations, RVRAT, fiche avis travaux. Dossier complet cohérent et défendable
							pour passage en commission.
						</p>
					</article>

					<article class="svc">
						<h3>Coordination levées de réserves</h3>
						<p>
							Pilotage des actions correctives demandées par le bureau de contrôle :
							coordination entreprises, suivi, validation, représentation devant BC.
						</p>
					</article>

					<article class="svc">
						<h3>Analyse PV &amp; conformité produits</h3>
						<p>
							Lecture critique des PV techniques, certificats coupe-feu, DoP, FDS.
							Détection des pièges et incohérences avant dépôt en commission.
						</p>
					</article>

					<article class="svc">
						<h3>Accompagnement ouverture ERP</h3>
						<p>
							De la reprise de dossier à l'arrêté d'ouverture : audit initial,
							coordination travaux conformité, interface BC, constitution dossier,
							présence commission.
						</p>
					</article>
				</div>
			</section>

			<section class="case-study">
				<h2>Étude de cas — AG Bar (Altkirch)</h2>
				<p class="case-intro">
					Aménagement Bar / Restaurant. Coordination complète jusqu'à la validation commission de sécurité.
				</p>

				<div class="case-grid">
					<div class="case-block">
						<h3>Documents traités</h3>
						<ul>
							<li>Certificats coupe-feu JWA T30, PV Schertzinger (alarme incendie)</li>
							<li>PV HUG Fluides (désenfumage / extraction)</li>
							<li>PV cloisons Knauf EI60 et EI120</li>
							<li>DOP faux plafonds, documents NF SSI</li>
							<li>FDS Protecflam / Heat Top Coat</li>
							<li>Attestation accessibilité ERP, rapport RVRAT, fiche avis travaux</li>
						</ul>
					</div>

					<div class="case-block">
						<h3>Mises en conformité réalisées</h3>
						<ul>
							<li>Suppression mur végétalisé (élément combustible)</li>
							<li>Traitement coupe-feu des traversées</li>
							<li>Rebouchage réservations et linteaux</li>
							<li>Mise en conformité installations techniques</li>
							<li>Vérification SSI et désenfumage</li>
						</ul>
					</div>

					<div class="case-block">
						<h3>Résultat</h3>
						<ul>
							<li>Dossier complet, cohérent et défendable</li>
							<li>Validation commission de sécurité</li>
							<li>Autorisation d'ouverture de l'établissement</li>
						</ul>
					</div>
				</div>
			</section>

			<section class="skills-section">
				<h2>Compétences mobilisées</h2>
				<div class="skills-grid">
					<div class="skill"><strong>Coordination générale</strong> des travaux de conformité</div>
					<div class="skill"><strong>Suivi conformité</strong> sécurité incendie</div>
					<div class="skill"><strong>Interface</strong> bureau de contrôle / entreprises / propriétaire</div>
					<div class="skill"><strong>Gestion</strong> des levées de réserves</div>
					<div class="skill"><strong>Constitution</strong> dossier commission de sécurité</div>
					<div class="skill"><strong>Pilotage</strong> des mises en conformité ERP</div>
					<div class="skill"><strong>Analyse</strong> technique des PV et documents réglementaires</div>
					<div class="skill"><strong>Réactivité terrain</strong> et adaptation contraintes chantier</div>
				</div>
			</section>

			<section class="legal-section">
				<h2>Cadre légal</h2>
				<div class="legal-grid">
					<div class="legal-item">
						<h3>DUER — Code du travail</h3>
						<p>Articles <strong>L.4121-1 à L.4121-5</strong>. Amende jusqu'à 1 500 €/unité de travail. Responsabilité pénale du dirigeant en cas d'accident.</p>
					</div>
					<div class="legal-item">
						<h3>ERP — Code construction habitation</h3>
						<p>Articles <strong>R.143-1 et suivants</strong>. Tout établissement recevant du public doit être visité par la commission de sécurité avant ouverture.</p>
					</div>
					<div class="legal-item">
						<h3>Accessibilité ERP</h3>
						<p>Obligations adaptation PMR depuis la loi de 2005. Attestation obligatoire au dossier.</p>
					</div>
					<div class="legal-item">
						<h3>Mise à jour annuelle</h3>
						<p>DUER annuel obligatoire + révision à chaque changement (nouveau poste, matériel, aménagement).</p>
					</div>
				</div>
			</section>

			<p class="disclaimer">
				<strong>Mention :</strong> Missions d'assistance, d'analyse, de coordination et de constitution de dossiers
				menées en parallèle d'une activité principale d'infrastructure télécom et scan 3D.
				La responsabilité finale du document DUER, des mesures de sécurité et du fonctionnement de l'établissement
				reste celle du chef d'établissement / exploitant (articles L.4121-1 du Code du travail et R.143-1 du CCH).
				Je n'endosse pas le rôle de préventeur salarié, d'organisme agréé ni de bureau de contrôle.
			</p>
		</main>
		<Footer />
	</body>
</html>

<style>
	.intro-block {
		padding: 2em 2em 2.5em;
		background: var(--bg-elevated);
		border: 1px solid var(--border);
		border-radius: 12px;
		margin-bottom: 3em;
	}
	h1 { margin: 0 0 0.5em; }
	.lede {
		font-size: 1.15em;
		color: var(--text);
		margin-bottom: 1.5em;
		line-height: 1.7;
	}
	.lede strong { color: var(--accent); }
	.refs {
		font-size: 0.9em;
		color: var(--text-muted);
		padding: 0.7em 1em;
		background: var(--bg);
		border-left: 3px solid var(--success);
		border-radius: 4px;
	}
	.refs strong { color: var(--text); }
	.ref-label { color: var(--text-dim); text-transform: uppercase; font-size: 0.82em; letter-spacing: 0.08em; margin-right: 0.6em; }

	.svc-section { margin-bottom: 3em; }
	.section-desc { color: var(--text-muted); font-style: italic; margin: -0.3em 0 1.5em; line-height: 1.6; }
	.proof {
		font-size: 0.9em;
		color: var(--text-muted);
		font-style: italic;
		padding: 0.6em 1em;
		background: var(--bg-code);
		border-left: 2px solid var(--accent);
		border-radius: 4px;
		margin: 0 0 1.5em;
	}
	.proof strong { color: var(--accent); font-style: normal; }
	.services {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 1em;
	}
	.svc {
		padding: 1.3em 1.4em;
		background: var(--bg-elevated);
		border: 1px solid var(--border);
		border-radius: 8px;
		transition: border-color 0.15s, transform 0.15s;
	}
	.svc:hover { border-color: var(--accent); transform: translateY(-2px); }
	.svc-highlight {
		border-color: var(--accent);
		background: linear-gradient(135deg, var(--bg-elevated) 0%, rgba(88, 166, 255, 0.08) 100%);
	}
	.svc h3 {
		margin: 0 0 0.5em;
		font-size: 1.05em;
		color: var(--accent);
	}
	.svc h3::before { content: ''; }
	.svc p {
		color: var(--text-muted);
		font-size: 0.95em;
		margin: 0;
	}

	.case-study {
		margin: 3em 0;
		padding: 2em;
		background: linear-gradient(135deg, var(--bg-elevated) 0%, rgba(63, 185, 80, 0.04) 100%);
		border: 1px solid var(--success);
		border-radius: 12px;
	}
	.case-study h2 { color: var(--success); margin-top: 0; }
	.case-study h2::before { color: var(--success); }
	.case-intro {
		font-size: 1.05em;
		color: var(--text);
		margin-bottom: 1.5em;
	}
	.case-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 1.2em;
		margin-top: 1em;
	}
	.case-block {
		padding: 1.2em;
		background: var(--bg);
		border: 1px solid var(--border);
		border-radius: 8px;
	}
	.case-block h3 {
		margin: 0 0 0.6em;
		font-size: 0.95em;
		color: var(--accent);
	}
	.case-block h3::before { content: ''; }
	.case-block ul { padding-left: 1.2em; margin: 0; }
	.case-block li { margin-bottom: 0.35em; color: var(--text-muted); font-size: 0.88em; line-height: 1.5; }

	.skills-section { margin: 3em 0; }
	.skills-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 0.8em;
		margin-top: 1em;
	}
	.skill {
		padding: 0.8em 1em;
		background: var(--bg-elevated);
		border-left: 2px solid var(--accent);
		border-radius: 4px;
		color: var(--text-muted);
		font-size: 0.92em;
	}
	.skill strong { color: var(--text); }

	.legal-section { margin: 3em 0; }
	.legal-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 1em;
		margin-top: 1em;
	}
	.legal-item {
		padding: 1.2em 1.3em;
		background: var(--bg-elevated);
		border: 1px solid var(--border);
		border-radius: 8px;
	}
	.legal-item h3 {
		margin: 0 0 0.5em;
		font-size: 0.98em;
		color: var(--accent);
	}
	.legal-item h3::before { content: ''; }
	.legal-item p { color: var(--text-muted); font-size: 0.88em; margin: 0; line-height: 1.55; }
	.legal-item strong { color: var(--text); }

	.disclaimer {
		margin: 3em 0 1em;
		padding: 1.2em 1.4em;
		background: var(--bg-code);
		border-left: 3px solid var(--text-dim);
		border-radius: 4px;
		color: var(--text-dim);
		font-size: 0.85em;
		font-style: italic;
		line-height: 1.7;
	}
	.disclaimer strong { color: var(--text-muted); font-style: normal; }
</style>
