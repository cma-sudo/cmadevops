---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ChatWidget from '../components/ChatWidget.astro';
import { SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="fr">
    <head>
        <BaseHead
            title={`Sécurisation & partage des données — Proposition Pierre Koch · ${SITE_TITLE}`}
            description="Proposition de migration Dropbox → Infomaniak kSuite Entreprise pour Pierre Koch Architecte. Sécurisation des données d'agence, hébergement souverain suisse, écosystème collaboratif."
        />
        <meta name="robots" content="noindex,nofollow,noarchive" />
    </head>
    <body>
        <Header />
        <main>

            <!-- INTRO -->
            <section class="intro-block">
                <p class="doc-meta">
                    <span class="doc-tag">Proposition confidentielle</span>
                    <span class="doc-date">Avril 2026</span>
                </p>
                <h1>Sécuriser, stocker &amp; partager<br><span class="accent-italic">vos données d'agence</span>.</h1>
                <p class="lede">
                    Proposition préparée pour <strong>Pierre Koch Architecte</strong> — migration de Dropbox vers
                    <strong>Infomaniak kSuite Entreprise</strong>. Un stockage souverain, un écosystème
                    collaboratif, une économie nette sur trois ans.
                </p>
                <div class="hero-meta">
                    <div class="meta-col">
                        <span class="label">Client</span>
                        <span class="value">Pierre Koch Architecte</span>
                    </div>
                    <div class="meta-col">
                        <span class="label">Objet</span>
                        <span class="value">Migration Dropbox → kSuite</span>
                    </div>
                    <div class="meta-col">
                        <span class="label">Économie 3 ans</span>
                        <span class="value highlight">— 345 € TTC</span>
                    </div>
                </div>
            </section>

            <!-- 01 CONSTAT -->
            <section class="svc-section">
                <h2>Le constat</h2>
                <p class="section-desc">Stockage saturé, outils fragmentés, image pro à consolider.</p>
                <p class="proof">
                    Vos 3 To Dropbox sont pleins. Votre messagerie <strong>@pkarchi</strong> est hébergée séparément.
                    Vos liens de partage client restent génériques. Une montée en gamme est inévitable — autant
                    en profiter pour gagner en cohérence, en sécurité et en image de marque.
                </p>

                <div class="compare-grid">

                    <article class="compare-card current">
                        <header>
                            <span class="compare-tag">Aujourd'hui</span>
                            <h3>État actuel</h3>
                        </header>
                        <div class="big-stat">
                            <span class="big-num">3</span>
                            <span class="big-unit">To saturés</span>
                        </div>
                        <p class="compare-sub">Dropbox + mail pro externe</p>
                        <ul class="compare-list">
                            <li><span>Stockage Dropbox</span><code class="neg">3 To plein</code></li>
                            <li><span>Mail @pkarchi + domaine</span><code class="neg">120 €/an</code></li>
                            <li><span>Historique fichiers</span><code class="neg">30 jours</code></li>
                            <li><span>Hébergement</span><code class="neg">États-Unis</code></li>
                            <li><span>Visio, chat, IA, branding</span><code class="neg">—</code></li>
                            <li><span>Coût annuel cumulé</span><code class="neg strong">290 €</code></li>
                        </ul>
                    </article>

                    <article class="compare-card target">
                        <header>
                            <span class="compare-tag target-tag">Recommandation</span>
                            <h3>État cible</h3>
                        </header>
                        <div class="big-stat">
                            <span class="big-num">6</span>
                            <span class="big-unit">To confortables</span>
                        </div>
                        <p class="compare-sub">kSuite Entreprise — tout-en-un</p>
                        <ul class="compare-list">
                            <li><span>Stockage kDrive</span><code class="pos">6 To</code></li>
                            <li><span>10 adresses @pkarchi</span><code class="pos">incluses</code></li>
                            <li><span>Historique fichiers</span><code class="pos">1 an</code></li>
                            <li><span>Hébergement</span><code class="pos">Suisse · RGPD+nLPD</code></li>
                            <li><span>Visio, chat, IA, Custom Brand</span><code class="pos">inclus</code></li>
                            <li><span>Coût annuel cumulé</span><code class="pos strong">204 €</code></li>
                        </ul>
                    </article>

                </div>
            </section>

            <!-- 02 CHIFFRAGE -->
            <section class="svc-section">
                <h2>Le chiffrage</h2>
                <p class="section-desc">Projection sur trois ans — tous montants en euros TTC.</p>

                <div class="price-block">
                    <table class="price-table">
                        <thead>
                            <tr>
                                <th>Année</th>
                                <th>Détail</th>
                                <th class="num-col">Actuel</th>
                                <th class="num-col">kSuite Ent.</th>
                                <th class="num-col">Économie</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><strong>An 1</strong></td>
                                <td>Promo lancement —50%</td>
                                <td class="num-col">290 €</td>
                                <td class="num-col">117 €</td>
                                <td class="num-col saving">— 173 €</td>
                            </tr>
                            <tr>
                                <td><strong>An 2</strong></td>
                                <td>Tarif régulier (engagement 3 ans)</td>
                                <td class="num-col">290 €</td>
                                <td class="num-col">204 €</td>
                                <td class="num-col saving">— 86 €</td>
                            </tr>
                            <tr>
                                <td><strong>An 3</strong></td>
                                <td>Tarif régulier (engagement 3 ans)</td>
                                <td class="num-col">290 €</td>
                                <td class="num-col">204 €</td>
                                <td class="num-col saving">— 86 €</td>
                            </tr>
                            <tr class="total-row">
                                <td></td>
                                <td><strong>Cumul trois ans</strong></td>
                                <td class="num-col"><strong>870 €</strong></td>
                                <td class="num-col"><strong>525 €</strong></td>
                                <td class="num-col saving"><strong>— 345 €</strong></td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <blockquote class="pullquote">
                    Pour le <em>même budget</em> qu'aujourd'hui, vous doublez votre stockage et vous ajoutez
                    un écosystème complet : mail pro, visio, chat, IA, branding, historique d'un an.
                </blockquote>
            </section>

            <!-- 03 DROPBOX vs KSUITE -->
            <section class="svc-section">
                <h2>Dropbox ↔ kSuite, fonctionnalité par fonctionnalité</h2>
                <p class="section-desc">Ce qui est <em>identique</em>, <em>supérieur</em> ou <em>différent</em>.</p>
                <p class="proof">
                    L'ergonomie Dropbox que vous connaissez est préservée. Les fonctionnalités avancées de Dropbox
                    Business (payant à part) deviennent natives et illimitées. Deux différences réelles à connaître :
                    la sync bloc-par-bloc et le chiffrement bout-en-bout.
                </p>

                <div class="feature-table-wrap">
                    <table class="feature-table">
                        <thead>
                            <tr>
                                <th>Fonctionnalité</th>
                                <th>Dropbox aujourd'hui</th>
                                <th>kSuite Entreprise</th>
                                <th class="status-col">Verdict</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><strong>App bureau &amp; sync</strong></td>
                                <td>Dropbox Desktop</td>
                                <td>kDrive Desktop (Mac/Win/Linux)</td>
                                <td class="status equal">=</td>
                            </tr>
                            <tr>
                                <td><strong>Fichiers à la demande</strong></td>
                                <td>Smart Sync</td>
                                <td>LiteSync (inclus)</td>
                                <td class="status equal">=</td>
                            </tr>
                            <tr>
                                <td><strong>Sync bloc-par-bloc</strong></td>
                                <td class="dbx">Oui (fichiers &gt; 100 Mo plus rapides)</td>
                                <td class="ksu">Non (upload complet)</td>
                                <td class="status minus">—</td>
                            </tr>
                            <tr>
                                <td><strong>Versioning fichiers</strong></td>
                                <td>30 jours</td>
                                <td class="ksu"><strong>365 jours · 200 versions</strong></td>
                                <td class="status plus">+</td>
                            </tr>
                            <tr>
                                <td><strong>Collaboration simultanée</strong></td>
                                <td>Via Dropbox Paper</td>
                                <td>OnlyOffice natif (Word/Excel/PPT)</td>
                                <td class="status plus">+</td>
                            </tr>
                            <tr>
                                <td><strong>Intégration MS Office / Adobe</strong></td>
                                <td>Oui</td>
                                <td>Oui (OnlyOffice + ouverture locale)</td>
                                <td class="status equal">=</td>
                            </tr>
                            <tr>
                                <td><strong>Apps mobiles iOS / Android</strong></td>
                                <td>Oui</td>
                                <td>Oui (kDrive, Mail, kMeet, kChat)</td>
                                <td class="status equal">=</td>
                            </tr>
                            <tr>
                                <td><strong>Partage par lien</strong></td>
                                <td>Lien dropbox.com générique</td>
                                <td class="ksu"><strong>partage.pkarchi.fr</strong> (Custom Brand)</td>
                                <td class="status plus">+</td>
                            </tr>
                            <tr>
                                <td><strong>Boîtes de dépôt client</strong></td>
                                <td>Dropbox File Requests (payant)</td>
                                <td class="ksu"><strong>Illimitées natif</strong></td>
                                <td class="status plus">+</td>
                            </tr>
                            <tr>
                                <td><strong>Recherche full-text</strong></td>
                                <td>Oui (plans payants)</td>
                                <td>Oui</td>
                                <td class="status equal">=</td>
                            </tr>
                            <tr>
                                <td><strong>Transfert volumineux</strong></td>
                                <td>Dropbox Transfer 100 Go (Business+)</td>
                                <td class="ksu">SwissTransfer 50 Go (intégré)</td>
                                <td class="status equal">≈</td>
                            </tr>
                            <tr>
                                <td><strong>Messagerie pro @pkarchi</strong></td>
                                <td class="dbx">Externe (+ 120 €/an)</td>
                                <td class="ksu"><strong>10 adresses incluses</strong></td>
                                <td class="status plus">+</td>
                            </tr>
                            <tr>
                                <td><strong>Visio intégrée</strong></td>
                                <td class="dbx">Non (via Zoom/Teams externes)</td>
                                <td class="ksu">kMeet illimité</td>
                                <td class="status plus">+</td>
                            </tr>
                            <tr>
                                <td><strong>Chat équipe &amp; externes</strong></td>
                                <td class="dbx">Non (via Slack/Teams)</td>
                                <td class="ksu">kChat 200 invités externes</td>
                                <td class="status plus">+</td>
                            </tr>
                            <tr>
                                <td><strong>Assistant IA</strong></td>
                                <td>Dropbox Dash (bêta, add-on)</td>
                                <td class="ksu">Euria (capacités max incluses)</td>
                                <td class="status plus">+</td>
                            </tr>
                            <tr>
                                <td><strong>Authentification 2FA</strong></td>
                                <td>Oui</td>
                                <td>Oui (app, clé FIDO2, SMS)</td>
                                <td class="status equal">=</td>
                            </tr>
                            <tr>
                                <td><strong>Chiffrement bout-en-bout</strong></td>
                                <td class="dbx">Non</td>
                                <td class="ksu">Non (TLS + AES-256 au repos)</td>
                                <td class="status equal">=</td>
                            </tr>
                            <tr>
                                <td><strong>Datacenter</strong></td>
                                <td class="dbx">États-Unis (Cloud Act)</td>
                                <td class="ksu"><strong>Suisse · RGPD + nLPD</strong></td>
                                <td class="status plus">+</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <p class="verdict-note">
                    <strong>15 fonctionnalités identiques ou supérieures</strong>, 1 vraie différence à accepter
                    (sync bloc-par-bloc sur gros fichiers — impact limité en usage asynchrone).
                </p>
            </section>

            <!-- 04 GAINS -->
            <section class="svc-section">
                <h2>Ce que vous gagnez</h2>
                <p class="section-desc">Neuf gains tangibles, au-delà du simple stockage.</p>

                <div class="services">

                    <article class="svc">
                        <header>
                            <h3>6 To extensibles</h3>
                            <span class="price">stockage</span>
                        </header>
                        <p>Le double d'aujourd'hui. Nuages de points LiDAR actifs directement dans le cloud. Extensible jusqu'à 106 To par paliers ou par ajout d'utilisateur.</p>
                        <div class="stack"><span class="tag">kdrive</span><span class="tag">6-to</span></div>
                    </article>

                    <article class="svc">
                        <header>
                            <h3>10 adresses @pkarchi</h3>
                            <span class="price">mail</span>
                        </header>
                        <p>Conservation de votre identité actuelle. Stockage mail illimité, pièces jointes jusqu'à 3 Go, chiffrement des messages.</p>
                        <div class="stack"><span class="tag">mail-pro</span><span class="tag">domaine</span></div>
                    </article>

                    <article class="svc">
                        <header>
                            <h3>Historique sur un an</h3>
                            <span class="price">protection</span>
                        </header>
                        <p>200 versions conservées pendant 365 jours. Vraie protection anti-ransomware : retour arrière possible sur toute l'année écoulée.</p>
                        <div class="stack"><span class="tag">ransomware</span><span class="tag">versioning</span></div>
                    </article>

                    <article class="svc">
                        <header>
                            <h3>Boîtes de dépôt illimitées</h3>
                            <span class="price">partage</span>
                        </header>
                        <p>Vos clients déposent leurs documents sur un lien dédié, sans créer de compte. Fonction premium Dropbox, native et illimitée ici.</p>
                        <div class="stack"><span class="tag">clients</span><span class="tag">upload</span></div>
                    </article>

                    <article class="svc svc-highlight">
                        <header>
                            <h3>⭐ Custom Brand inclus</h3>
                            <span class="price">image</span>
                        </header>
                        <p>URL personnalisée <code>partage.pkarchi.fr</code>, interface de connexion à vos couleurs, liens de partage brandés avec votre logo. L'image d'agence renforcée sans lien générique.</p>
                        <div class="stack"><span class="tag">branding</span><span class="tag">url-perso</span></div>
                    </article>

                    <article class="svc">
                        <header>
                            <h3>SwissTransfer 50 Go</h3>
                            <span class="price">transfert</span>
                        </header>
                        <p>Envoi de nuages de points ou maquettes Revit volumineux aux BET et entreprises, sans saturer les boîtes mail. Intégré nativement.</p>
                        <div class="stack"><span class="tag">swisstransfer</span><span class="tag">50-go</span></div>
                    </article>

                    <article class="svc">
                        <header>
                            <h3>Visio &amp; messagerie équipe</h3>
                            <span class="price">collaboration</span>
                        </header>
                        <p>kMeet pour les réunions client illimitées. kChat pour la messagerie jusqu'à 200 invités externes (BET, MOE, entreprises chantier).</p>
                        <div class="stack"><span class="tag">kmeet</span><span class="tag">kchat</span></div>
                    </article>

                    <article class="svc">
                        <header>
                            <h3>IA Euria capacités max</h3>
                            <span class="price">ia</span>
                        </header>
                        <p>Rédaction mails et devis, résumés de réunion, analyse des fichiers kDrive, transcription illimitée. L'IA éthique souveraine intégrée.</p>
                        <div class="stack"><span class="tag">euria</span><span class="tag">ia-ethique</span></div>
                    </article>

                    <article class="svc">
                        <header>
                            <h3>RGPD · nLPD · 100% suisse</h3>
                            <span class="price">souveraineté</span>
                        </header>
                        <p>Données hébergées en Suisse dans les datacenters Infomaniak. Conformité juridique renforcée — argument décisif pour les marchés publics en Alsace.</p>
                        <div class="stack"><span class="tag">rgpd</span><span class="tag">nlpd</span><span class="tag">suisse</span></div>
                    </article>

                </div>
            </section>

            <!-- 04 TRANSPARENCE -->
            <section class="svc-section">
                <h2>Transparence</h2>
                <p class="section-desc">Ce qui est largement gagné, ce qui demande un ajustement.</p>

                <div class="balance-grid">

                    <div class="balance-col pros">
                        <h3 class="balance-title">+ Les vrais gains</h3>
                        <ul class="balance-list">
                            <li>
                                <strong>Même confort bureau ↔ maison</strong>
                                App kDrive Desktop identique à Dropbox, LiteSync inclus (fichiers visibles sans occuper le disque).
                            </li>
                            <li>
                                <strong>Protection juridique forte</strong>
                                RGPD + nLPD suisse, argument différenciant sur les appels d'offres de collectivités en Alsace.
                            </li>
                            <li>
                                <strong>Stack simplifié</strong>
                                Un seul prestataire pour stockage, mail, visio, chat, IA. Une facture unique, un support unique.
                            </li>
                            <li>
                                <strong>Marge d'évolution</strong>
                                Extension jusqu'à 106 To, ajout d'utilisateurs à tout moment, migration simple depuis Dropbox via outil natif.
                            </li>
                        </ul>
                    </div>

                    <div class="balance-col cons">
                        <h3 class="balance-title">— Points d'attention</h3>
                        <ul class="balance-list">
                            <li>
                                <strong>Sync bloc-par-bloc absente</strong>
                                Sur un Revit de 300 Mo, l'upload prend 1–2 minutes contre quelques secondes sur Dropbox. Impact limité en usage asynchrone.
                            </li>
                            <li>
                                <strong>Marque moins universelle</strong>
                                Certains clients moins familiers qu'avec Dropbox. Compensé par le Custom Brand qui remplace l'URL Infomaniak par pkarchi.fr.
                            </li>
                            <li>
                                <strong>Pas de chiffrement bout-en-bout</strong>
                                Infomaniak peut techniquement accéder aux données (comme Dropbox). VeraCrypt possible sur les dossiers sensibles si besoin.
                            </li>
                            <li>
                                <strong>Migration 3 To à préparer</strong>
                                Transfert via l'outil Import Cloud Infomaniak (3 à 7 jours en arrière-plan). Sans interruption d'activité.
                            </li>
                        </ul>
                    </div>

                </div>
            </section>

            <!-- 06 ARCHITECTURE 3-2-1 -->
            <section class="svc-section">
                <h2>Architecture recommandée : règle 3-2-1</h2>
                <p class="section-desc">Trois copies, deux supports différents, une hors-site. La règle d'or du stockage pro.</p>
                <p class="proof">
                    kSuite couvre déjà 2 des 3 piliers (cloud souverain + versioning 365 jours). Pour un
                    archi qui détient les plans et nuages LiDAR de ses clients pendant dix ans, j'ajoute un
                    NAS local à la <strong>maison où vous avez la fibre</strong> — un achat <strong>one-shot
                    de ~840 € TTC</strong> qui vous donne une copie 100&nbsp;% sous votre contrôle.
                </p>

                <div class="threetwoone-grid">
                    <article class="copy-card copy-1">
                        <header>
                            <span class="copy-num">1</span>
                            <h3>kSuite Entreprise</h3>
                            <span class="copy-role">Copie primaire · travail quotidien</span>
                        </header>
                        <p>Cloud Infomaniak Suisse. Accessible depuis la maison en fibre et le bureau en 5G, sans VPN ni config. Versioning 365 jours, boîtes de dépôt clients, mail pro, visio.</p>
                        <div class="copy-meta">
                            <span class="meta-item">Récurrent</span>
                            <span class="meta-item">6 To</span>
                            <span class="meta-item">204 €/an</span>
                        </div>
                    </article>

                    <article class="copy-card copy-2">
                        <header>
                            <span class="copy-num">2</span>
                            <h3>NAS Synology maison</h3>
                            <span class="copy-role">Copie locale · backup auto quotidien</span>
                        </header>
                        <p>HyperBackup de kDrive vers NAS chaque nuit. Redondance RAID 1 (1 disque peut mourir). Snapshots Btrfs = rollback instantané anti-ransomware. Archivage projets clôturés pour alléger kDrive.</p>
                        <div class="copy-meta">
                            <span class="meta-item">One-shot</span>
                            <span class="meta-item">6 To miroir</span>
                            <span class="meta-item">~840 € TTC</span>
                        </div>
                    </article>

                    <article class="copy-card copy-3">
                        <header>
                            <span class="copy-num">3</span>
                            <h3>Disque chiffré bureau</h3>
                            <span class="copy-role">Copie hors-site · rotation mensuelle</span>
                        </header>
                        <p>Disque dur USB chiffré VeraCrypt, copie incrémentale du NAS chaque début de mois, transporté au bureau. Protection vol / incendie / dégât des eaux à la maison.</p>
                        <div class="copy-meta">
                            <span class="meta-item">One-shot</span>
                            <span class="meta-item">8 To</span>
                            <span class="meta-item">~190 € TTC</span>
                        </div>
                    </article>
                </div>

                <h3 class="sub-h3">Équipement NAS recommandé</h3>
                <p class="section-desc">Une recommandation matérielle, pas une prestation. Vous l'achetez et l'installez.</p>

                <div class="gear-block">
                    <div class="gear-main">
                        <div class="gear-title-row">
                            <h4>Synology DS225+ &mdash; 2 baies</h4>
                            <span class="gear-price">359 €</span>
                        </div>
                        <ul class="gear-specs">
                            <li>Processeur Intel Celeron J4125 · 2 Go RAM DDR4</li>
                            <li>Port 2,5 GbE (transferts rapides depuis Mac)</li>
                            <li>Système de fichiers Btrfs (snapshots anti-ransomware)</li>
                            <li>DSM 7.2 : HyperBackup, Synology Drive, Photos, Docker</li>
                            <li>Consommation ~15 W · silencieux · garantie constructeur 2 ans</li>
                        </ul>
                    </div>
                    <div class="gear-main">
                        <div class="gear-title-row">
                            <h4>2 × WD Red Plus 6 To</h4>
                            <span class="gear-price">480 €</span>
                        </div>
                        <ul class="gear-specs">
                            <li>Disques durs conçus pour NAS 24/7</li>
                            <li>Technologie CMR (pas SMR) · 5 400 tr/min · 256 Mo cache</li>
                            <li>Garantie constructeur 3 ans</li>
                            <li>Configuration RAID 1 = 6 To utiles en miroir</li>
                            <li>Match la capacité kSuite pour miroir exact</li>
                        </ul>
                    </div>
                    <div class="gear-total">
                        <span class="gear-total-label">Total équipement TTC</span>
                        <span class="gear-total-price">≈ 840 €</span>
                        <span class="gear-total-note">Achat unique · amortissement 5 ans</span>
                    </div>
                </div>

                <div class="insight-box">
                    <h4>À retenir sur le NAS</h4>
                    <ul class="insight-list">
                        <li><strong>Backup uniquement, pas d'accès bureau en 5G</strong> — la latence 5G et la dépendance à votre fibre maison rendraient l'usage quotidien pénible. Le travail reste sur le cloud kDrive, identique à aujourd'hui.</li>
                        <li><strong>Économie long terme</strong> — 840 € one-shot ≈ 4 ans d'abonnement 6 To sur cloud séparé. Au-delà, le NAS est amorti.</li>
                        <li><strong>Usage secondaire possible</strong> — Photos famille, sauvegarde Time Machine des Mac, serveur VPN perso, cloud privé pour fichiers sensibles non clients.</li>
